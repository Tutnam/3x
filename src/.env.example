# Bot Configuration
BOT_TOKEN=your_bot_token_here
ADMINS=123456789,987654321

# 3x-UI Panel Settings
XUI_API_URL=https://your-panel.com
XUI_BASE_PATH=/panel
XUI_USERNAME=admin
XUI_PASSWORD=admin
XUI_HOST=your-server.com
XUI_SERVER_NAME=domain.com

# VLESS Public Settings (optional, if different from XUI_HOST)
VLESS_PUBLIC_HOST=
VLESS_PUBLIC_PORT=

# Payment Settings
PAYMENT_TOKEN=your_payment_token

# Inbound Settings
INBOUND_ID=1

# Reality Settings
REALITY_PUBLIC_KEY=your_public_key
REALITY_FINGERPRINT=chrome
REALITY_SNI=example.com
REALITY_SHORT_ID=1234567890
REALITY_SPIDER_X=/
REALITY_FLOW=

# VLESS Settings
VLESS_ENCRYPTION=none

# Subscription Server Settings
SUBSCRIPTION_HOST=0.0.0.0
SUBSCRIPTION_PORT=8080
SUBSCRIPTION_BASE_URL=http://your-domain.com:8080
